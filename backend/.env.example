PORT=5000
DATABASE_URL="postgresql://username:password@localhost:5432/your_database_name?schema=public"
JWT_SECRET="your_jwt_secret_key_here"

# WhatsApp Business API Credentials
WHATSAPP_ACCESS_TOKEN="your_whatsapp_access_token_here"
WHATSAPP_PHONE_NUMBER_ID="your_whatsapp_phone_number_id_here"
WHATSAPP_VERIFY_TOKEN="your_verify_token_here"

# WhatsApp Notification Templates
WHATSAPP_TEMPLATE_REGISTRATION="appointment_confirmation_1"
WHATSAPP_TEMPLATE_REMINDER="vaccination_reminder_1"
WHATSAPP_TEMPLATE_COMPLETED="vaccination_successful_1"
WHATSAPP_TEMPLATE_LANGUAGE="en_US"

# Application Settings
WHATSAPP_FRONTEND_URL="http://localhost:5173"
WHATSAPP_SCHEDULER_INTERVAL_MS=10000
